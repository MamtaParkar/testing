<mvc:View xmlns:form="sap.ui.layout.form" controllerName="com.ibs.testproject.controller.MasterPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
    <content>
    <Table items="{StudentDetails>/Students}" backgroundDesign="Solid" >
    <columns>
    <Column>
    <Title text="Name"/>
    </Column>
    <Column>
    <Title text="Age" textAlign="Center"/>
    </Column>
    <Column>
    <Title text="City" textAlign="Center"/>
    </Column>
    <Column>
    <Title text="Division" textAlign="Center"/>
    </Column>
    <Column>
    <Title text="Roll_No." textAlign="Center"/>
    </Column>
        <Column>
    <Title text="Result" textAlign="Center"/>
    </Column>
    </columns>
    <items>
    <ColumnListItem type="Navigation" press="onStudentDetails">
    <cells>
    <Text text="{StudentDetails>Name}"/>
    <ObjectStatus text="{StudentDetails>Age} " 
    state="{=${StudentDetails>Age} > 18 ? 'Success': 'Error'}"/>    
    <!-- <Text text="{Age}"/> -->
   
    <Text text="{StudentDetails>City}"/>
   
    <Text text="{StudentDetails>Division}"/>
    
    <Text text="{StudentDetails>Roll_No}"/>
    
    <Text text="{=${StudentDetails>Passed} === true ? 'Passed':'Failed'}"  />
    </cells>
    </ColumnListItem>    
    </items>
    </Table>
    </content>
